// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @unique
  contractId      String
  ledger          Int
  timestamp       Int
  txHash          String
  topics          Json     // Store as JSON array (may contain "ipfs:<cid>" pointers)
  data            String   // Hex data (may contain "ipfs:<cid>" pointer if >2KB)
  description     String?  // Translated human-readable text
  status          String   // "translated" | "cryptic"
  blueprintName   String?  // Contract name from blueprint
  eventType       String?  // Event type (transfer, mint, burn, etc.)
  ipfsCids        Json?    // Array of IPFS CIDs offloaded for this event

  // Reconciliation fields
  rpcVerified     Boolean  @default(false)
  lastRpcCheck    DateTime?
  discrepancies   String?  // JSON array of issues

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([contractId])
  @@index([ledger])
  @@index([txHash])
  @@index([contractId, ledger])
  @@index([timestamp])
}

model DeadLetterEvent {
  id            String   @id @default(cuid()) @unique
  eventId       String
  contractId    String
  ledger        Int
  timestamp     Int
  txHash        String
  topics        Json
  data          String
  errorCode     String
  errorMessage  String
  errorStack    String?
  errorContext  Json?
  createdAt     DateTime @default(now())

  @@index([contractId])
  @@index([eventId])
  @@index([createdAt])
}

// Tracks the indexer's progress through ledgers
model IndexerCursor {
  id              String   @id @default("current")
  lastLedger      Int      @default(0)
  lastProcessed   DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Records reconciliation job executions
model ReconciliationJob {
  id              String   @id @default(cuid())
  status          String   // "pending" | "processing" | "completed" | "failed"
  startLedger     Int
  endLedger       Int

  eventsProcessed Int      @default(0)
  eventsMatched   Int      @default(0)
  eventsSkipped   Int      @default(0)
  eventsError     Int      @default(0)

  // Discrepancies found during reconciliation
  discrepancies   Json?    // Array of { ledger, eventId, issue, action }

  // Job metadata
  triggeredBy     String?  // "cron" | "manual" | admin user ID
  errorMessage    String?
  completedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Audit trail for reconciliation actions
model AuditLog {
  id              String   @id @default(cuid())
  jobId           String
  action          String   // "detected" | "fixed" | "flagged" | "verified"
  eventId         String?
  ledger          Int?
  details         Json     // Additional context
  metadata        Json?    // Request headers, IP, etc.

  createdAt       DateTime @default(now())

  @@index([jobId])
  @@index([eventId])
}

// Records every data-retention archive run for observability and audit
model ArchiveLog {
  id            String   @id @default(cuid())
  /// ISO cutoff date used for this run
  cutoffDate    DateTime
  /// Number of rows written to the archive flat file
  rowsArchived  Int      @default(0)
  /// Number of rows deleted from Event (should equal rowsArchived on success)
  rowsDeleted   Int      @default(0)
  /// Absolute path of the produced .csv.gz file (empty if no data / failure)
  archiveFile   String   @default("")
  /// Wall-clock duration in milliseconds
  durationMs    Int      @default(0)
  /// "success" | "failed" | "skipped"
  status        String   @default("success")
  /// Error message populated on failure
  errorMessage  String?
  /// "cron" | "manual"
  triggeredBy   String   @default("cron")

  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// Configuration for reconciliation
model ReconciliationConfig {
  id              String   @id @default("current")
  
  // Cron schedule (e.g., "0 2 * * *" for daily at 2 AM)
  cronSchedule    String   @default("0 2 * * *")
  
  // Batch size for processing
  batchSize       Int      @default(1000)
  
  // Number of days to look back for reconciliation
  lookbackDays    Int      @default(7)
  
  // Whether to auto-fix detected issues
  autoFix         Boolean  @default(false)
  
  // Alert threshold (percentage of discrepancies)
  alertThreshold  Float    @default(0.1) // 0.1% = 1 in 1000
  
  // Enable/disable reconciliation
  enabled         Boolean  @default(true)
  
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// Cross-Chain Bridge Tracking
// ============================================================================

// A single raw bridge event captured from either Stellar/Soroban or EVM
model BridgeEvent {
  id              String   @id @default(cuid())
  chain           String   // "stellar" | "ethereum" | "optimism" | "arbitrum" | "base"
  eventType       String   // "burn" | "mint"
  txHash          String
  blockNumber     BigInt
  timestamp       Int      // Unix timestamp (seconds)
  contractAddress String   // Bridge contract on the source chain
  sender          String?  // Original sender address
  recipient       String?  // Destination address
  token           String?  // Token symbol or address
  amount          String   // Amount as string (supports large numbers)
  destinationChain String? // Intended target chain declared in the event
  destinationProof String? // On-chain proof / nonce / message ID linking both sides
  rawPayload      Json     // Original raw log / event data

  matchId         String?  // FK → CrossChainMatch (nullable until matched)
  match           CrossChainMatch? @relation(fields: [matchId], references: [id])

  createdAt       DateTime @default(now())

  @@index([chain])
  @@index([eventType])
  @@index([txHash])
  @@index([timestamp])
  @@index([destinationProof])
  @@index([matchId])
}

// A confirmed cross-chain transfer: one Stellar Burn paired with one EVM Mint
model CrossChainMatch {
  id              String   @id @default(cuid())
  status          String   // "pending" | "matched" | "unmatched" | "disputed"

  // Scalar references so the match is self-contained even if events are pruned
  burnTxHash      String
  mintTxHash      String?  // null while waiting for the EVM mint to arrive
  burnChain       String   @default("stellar")
  mintChain       String   // "ethereum" | "optimism" | "arbitrum" | "base"

  token           String?
  amount          String
  sender          String?
  recipient       String?

  burnTimestamp   Int      // Unix seconds
  mintTimestamp   Int?     // null until matched
  latencySeconds  Int?     // mintTimestamp - burnTimestamp

  // The proof / nonce that deterministically links both sides
  destinationProof String?

  // Confidence score 0-100 (100 = proof-matched, lower = heuristic)
  matchConfidence Int      @default(0)
  matchMethod     String?  // "proof" | "amount+timestamp" | "amount+recipient"

  // Child bridge events
  events          BridgeEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([burnTxHash])
  @@index([destinationProof])
  @@index([createdAt])
}

// Webhook subscriptions
model WebhookSubscription {
  id              String   @id @default(cuid())
  name            String?
  url             String
  secret          String
  contractId      String
  eventTypes      Json?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  webhookDeliveries WebhookDelivery[]
  
  @@index([contractId])
  @@index([enabled])
}

// Webhook delivery attempts
model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  eventId         String
  contractId      String
  payload         Json
  status          String   // "pending" | "delivered" | "failed"
  attempts        Int      @default(0)
  maxAttempts     Int      @default(3)
  lastError       String?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  webhook         WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  @@index([webhookId])
  @@index([eventId])
  @@index([status])
}
