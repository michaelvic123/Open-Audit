# ============================================================================
# Open-Audit Microservices Architecture Configuration
# ============================================================================
# This configuration is for the decoupled microservices architecture where:
# - Indexer Worker runs independently (src/worker/indexer.ts)
# - Web Server runs independently (server-decoupled.ts)
# - Redis Pub/Sub connects them
#
# Copy this file to .env.local (for local development) or .env (for Docker)
# ============================================================================

# ============================================================================
# Stellar Network Configuration
# ============================================================================

# Network selection: "testnet" or "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# Horizon REST API endpoint (for testnet)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint (for testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase (testnet)
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# For mainnet, use these values instead:
# NEXT_PUBLIC_NETWORK=mainnet
# NEXT_PUBLIC_HORIZON_URL=https://horizon.stellar.org
# NEXT_PUBLIC_SOROBAN_RPC_URL=https://mainnet.stellar.validationcloud.io
# NEXT_PUBLIC_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"

# ============================================================================
# Redis Configuration (Message Broker)
# ============================================================================

# Redis connection URL
# - Local development: redis://localhost:6379
# - Docker Compose: redis://redis:6379 (uses service name)
# - Production: redis://your-redis-host:6379
REDIS_URL=redis://localhost:6379

# Redis Pub/Sub channel name for event streaming
REDIS_CHANNEL=stellar:events

# Redis connection pool settings (optional)
REDIS_MAX_RETRIES=10
REDIS_RETRY_DELAY_MS=1000

# ============================================================================
# Web Server Configuration (server-decoupled.ts)
# ============================================================================

# HTTP server port
PORT=3000

# Environment: "development" or "production"
NODE_ENV=development

# Maximum WebSocket connections per IP address (rate limiting)
MAX_WS_CONNECTIONS_PER_IP=5

# Health check reporting interval (milliseconds)
HEALTH_CHECK_INTERVAL_MS=30000

# ============================================================================
# Indexer Worker Configuration (src/worker/indexer.ts)
# ============================================================================

# Unique identifier for this worker instance
# Use different IDs if running multiple workers
WORKER_ID=indexer-worker-1

# Indexer mode: "stream" (real-time SSE) or "poll" (batch polling)
# Recommended: "stream" for real-time event delivery
INDEXER_MODE=stream

# Number of parallel worker threads for event processing
# Adjust based on CPU cores and load
INDEXER_WORKER_COUNT=4

# Maximum queue size for pending events
INDEXER_MAX_QUEUE_SIZE=1000

# Polling interval in milliseconds (only used if INDEXER_MODE=poll)
POLL_INTERVAL_MS=5000

# Enable resilience layer (rate limiting + circuit breaker)
# Set to "false" to disable for local development
ENABLE_RESILIENCE=true

# Optional: Filter by specific contract IDs (comma-separated)
# Leave empty to index all contracts
# CONTRACT_IDS=CABC123...,CDEF456...
CONTRACT_IDS=

# ============================================================================
# Database Configuration (Optional - for Prisma)
# ============================================================================

# PostgreSQL connection string
# - Local: postgresql://user:password@localhost:5432/openaudit
# - Docker: postgresql://user:password@postgres:5432/openaudit
DATABASE_URL=postgresql://openaudit:openaudit@localhost:5432/openaudit

# Database credentials (used by Docker Compose)
POSTGRES_USER=openaudit
POSTGRES_PASSWORD=openaudit
POSTGRES_DB=openaudit

# ============================================================================
# Monitoring & Observability (Optional)
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Log level: "debug", "info", "warn", "error"
LOG_LEVEL=info

# ============================================================================
# API Configuration (Optional)
# ============================================================================

# API Key Registry — comma-separated entries of "hashedKey:tier:appName"
# Generate a key pair via POST /api/developer/rotate-key
# Tiers: free (60 req/min) | partner (5000 req/min)
# Example: OA_API_KEYS="abc123...:free:my-wallet,def456...:partner:analytics-bot"
OA_API_KEYS=

# ============================================================================
# Docker Compose Specific (Only needed when using docker-compose.yml)
# ============================================================================

# These are automatically set by Docker Compose, but can be overridden
# REDIS_URL=redis://redis:6379
# DATABASE_URL=postgresql://openaudit:openaudit@postgres:5432/openaudit

# ============================================================================
# PM2 Specific (Only needed when using PM2 instead of Docker)
# ============================================================================

# PM2 will use the environment variables defined above
# Additional PM2 environment variables can be set in ecosystem.config.js

# ============================================================================
# Quick Start Guide
# ============================================================================

# OPTION 1: Local Development (Manual)
# 1. Install Redis: brew install redis (macOS) or apt install redis (Linux)
# 2. Start Redis: redis-server
# 3. Start Web Server: npm run dev:decoupled
# 4. Start Indexer Worker: npm run worker:indexer
# 5. Visit http://localhost:3000

# OPTION 2: Docker Compose (Recommended for Production-like setup)
# 1. Copy this file to .env
# 2. Start all services: npm run docker:up
# 3. View logs: npm run docker:logs
# 4. Stop all: npm run docker:down

# OPTION 3: PM2 (Process Manager)
# 1. Copy this file to .env.local
# 2. Start Redis: redis-server
# 3. Start all services: npm run start:pm2
# 4. Monitor: npm run monit:pm2
# 5. Stop all: npm run stop:pm2

# ============================================================================
# Architecture Benefits
# ============================================================================

# ✅ Zero CPU Starvation
# - Indexer worker runs in isolated process
# - Web server never blocked by blockchain polling
# - Smooth WebSocket connections under heavy load

# ✅ Independent Scaling
# - Scale web servers horizontally for more clients
# - Scale indexer workers for higher throughput
# - Scale Redis for message queue capacity

# ✅ Fault Isolation
# - Indexer crash doesn't affect web server
# - Web server restart doesn't lose indexing state
# - Redis auto-reconnect on both sides

# ✅ Zero Downtime Deployments
# - Rolling updates without dropping connections
# - Blue-green deployments per service
# - Graceful shutdown handlers (SIGTERM/SIGINT)

# ============================================================================
# Production Recommendations
# ============================================================================

# 1. Use managed Redis (AWS ElastiCache, Redis Cloud, etc.)
# 2. Set MAX_WS_CONNECTIONS_PER_IP based on expected load
# 3. Enable ENABLE_RESILIENCE=true for production
# 4. Use INDEXER_MODE=stream for real-time events
# 5. Set INDEXER_WORKER_COUNT based on CPU cores (e.g., 8-16)
# 6. Monitor health checks at /api/health
# 7. Set up log aggregation (PM2 logs, Docker logs, etc.)
# 8. Use SENTRY_DSN for error tracking
# 9. Configure firewall rules for Redis (port 6379)
# 10. Set strong POSTGRES_PASSWORD in production

# ============================================================================
# Troubleshooting
# ============================================================================

# Redis connection issues:
# - Check REDIS_URL is correct
# - Ensure Redis is running: redis-cli ping
# - Check firewall rules for port 6379

# No events received:
# - Check indexer worker logs for errors
# - Verify REDIS_CHANNEL matches on both worker and server
# - Ensure NEXT_PUBLIC_NETWORK matches Horizon endpoint
# - Check CONTRACT_IDS filter (empty = all contracts)

# WebSocket connection issues:
# - Verify WebSocket endpoint: ws://localhost:3000/ws/events
# - Check MAX_WS_CONNECTIONS_PER_IP not exceeded
# - Review browser console for connection errors

# Performance issues:
# - Increase INDEXER_WORKER_COUNT for parallel processing
# - Increase INDEXER_MAX_QUEUE_SIZE if queue fills up
# - Scale Redis for higher message throughput
# - Use Docker Compose resource limits

# Health check failures:
# - Visit http://localhost:3000/api/health
# - Check database connection (DATABASE_URL)
# - Verify services are running: docker ps or pm2 status

# ============================================================================
# Cross-Chain Bridge Tracker (EVM Bridge Indexer Worker)
# ============================================================================

# EVM RPC endpoints — comma-separated, chain-prefixed
# Format: chain:rpc_url[,chain2:rpc_url2,...]
# Supported chains: ethereum, optimism, arbitrum, base
# Example:
# EVM_RPC_ENDPOINTS=ethereum:https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY,optimism:https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
EVM_RPC_ENDPOINTS=

# Bridge contract addresses to watch — comma-separated, chain-prefixed
# Format: chain:0xAddress[,chain2:0xAddress2,...]
# Example:
# BRIDGE_CONTRACT_ADDRESSES=ethereum:0xAbCd1234...,optimism:0xEfGh5678...
BRIDGE_CONTRACT_ADDRESSES=

# Stellar bridge contract IDs to watch for Burn events (comma-separated)
# Leave empty to watch ALL burn events from all contracts
# Example:
# STELLAR_BRIDGE_CONTRACT_IDS=CABC...XYZ,CDEF...ABC
STELLAR_BRIDGE_CONTRACT_IDS=

# EVM poll interval in milliseconds (default 12000 = ~1 Ethereum block)
EVM_POLL_INTERVAL_MS=12000

# Maximum block range per getLogs call (default 500)
EVM_MAX_BLOCK_RANGE=500

# Redis channel for bridge events (separate from stellar:events)
REDIS_BRIDGE_CHANNEL=bridge:events
