# Version control
.git
.gitignore
.gitattributes

# Build outputs (rebuilt inside Docker)
.next
.server-dist
node_modules
dist

# Environment files — never bake secrets into images
.env*
!.env.example

# CI / tooling
.github
.kiro

# Documentation (not needed at build time)
*.md
docs/

# Test artefacts — excluded so clean builds skip test-only sources
coverage/
*.test.*
__tests__/
**/*.spec.ts
**/*.spec.tsx

# Local dev / editor noise
.DS_Store
*.log
Thumbs.db
.vscode
.idea

# Keep native addon sources and prisma schema — required by multi-stage build
!native/
!prisma/
