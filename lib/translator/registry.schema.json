{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grant-fox/Open-Audit/lib/translator/registry.schema.json",
  "title": "Open-Audit Translation Registry",
  "description": "Schema for the Open-Audit translation registry mapping. Validates an array of registry entries submitted via community PRs.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/registryEntry"
  },
  "uniqueItems": true,
  "$defs": {
    "registryEntry": {
      "type": "object",
      "required": ["contract_id", "topics", "event_structure", "templates"],
      "additionalProperties": false,
      "properties": {
        "contract_id": {
          "type": "string",
          "description": "The Soroban contract address this entry applies to",
          "minLength": 1
        },
        "topics": {
          "type": "array",
          "description": "Ordered list of event topic names (the first is the event discriminant)",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "event_structure": {
          "type": "object",
          "description": "Describes how the raw event's topics and data map to named, typed fields",
          "required": ["topics"],
          "additionalProperties": false,
          "properties": {
            "topics": {
              "type": "array",
              "description": "Fields extracted from event topics[1..] (topic[0] is the event name)",
              "items": {
                "type": "object",
                "required": ["name", "type"],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The field name used in the templates",
                    "minLength": 1
                  },
                  "type": {
                    "type": "string",
                    "description": "The Soroban type (address, i128, u32, u64, i64, symbol, bool, bytes)",
                    "enum": ["address", "i128", "u32", "u64", "i64", "symbol", "bool", "bytes"]
                  }
                }
              }
            },
            "data": {
              "type": "object",
              "description": "The field extracted from the event data payload (if any)",
              "required": ["name", "type"],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The field name used in the templates",
                  "minLength": 1
                },
                "type": {
                  "type": "string",
                  "description": "The Soroban type (address, i128, u32, u64, i64, symbol, bool, bytes)",
                  "enum": ["address", "i128", "u32", "u64", "i64", "symbol", "bool", "bytes"]
                }
              }
            }
          }
        },
        "templates": {
          "type": "object",
          "description": "Human-readable templates describing the event in different languages, using {field} placeholders",
          "required": ["en"],
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "properties": {
            "en": {
              "type": "string",
              "description": "English template",
              "minLength": 1
            },
            "es": {
              "type": "string",
              "description": "Spanish template",
              "minLength": 1
            },
            "fr": {
              "type": "string",
              "description": "French template",
              "minLength": 1
            },
            "zh": {
              "type": "string",
              "description": "Chinese template",
              "minLength": 1
            }
          }
        },
        "test_vectors": {
          "type": "array",
          "description": "Sample payloads used by CI to render preview translations in PRs",
          "items": {
            "type": "object",
            "required": ["params"],
            "additionalProperties": false,
            "properties": {
              "hex_payload": {
                "type": "string",
                "description": "Optional raw hex event payload for display purposes"
              },
              "params": {
                "type": "object",
                "description": "Resolved template parameter values, e.g. { from: 'GABC...', amount: 50000000 }",
                "additionalProperties": { "type": ["string", "number", "boolean"] }
              }
            }
          }
        }
      }
    }
  }
}
